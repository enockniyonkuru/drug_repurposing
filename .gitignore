############################
# Project-specific: Large files
############################
# Ignore large CMap signatures file (232MB - exceeds GitHub limit)
scripts/data/cmap_signatures.RData

# Ignore large gene conversion table (4.5MB)
scripts/data/gene_id_conversion_table.tsv

# Ignore any zip files (can be very large)
*.zip
scripts/data/*.zip

# Ignore all results directories (generated outputs)
scripts/results/*
!scripts/results/.gitkeep
!scripts/results/README.md

# Ignore cdrpipe_comparative_analysis results (large generated outputs)
cdrpipe_comparative_analysis/results/*
