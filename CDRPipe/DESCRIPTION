Package: CDRPipe
Type: Package
Title: CDRPipe Utilities for Drug Repurposing, Scoring, and Visualization
Version: 0.2.1
Authors@R: c(
    person(given = "Xinyu", family = "Tang", role = "aut", email = "Xinyu.Tang@ucsf.edu"),
    person(given = "Enock", family = "Niyonkuru", role = c("aut", "cre"), email = "enock.niyonkuru@ucsf.edu"),
    person(given = "Marina", family = "Sirota", role = "aut", email = "Marina.Sirota@ucsf.edu")
